<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      color: #333;
    }

    .header {
      background: #1554a1;
      color: white;
      padding: 30px;
      display: flex;
      justify-content: space-between;
    }

    .logo {
      font-size: 28px;
      font-weight: bold;
    }

    .invoice-info {
      text-align: right;
    }

    .section {
      padding: 30px;
    }

    h3 {
      color: #1554a1;
      margin-bottom: 5px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th {
      text-align: left;
      border-bottom: 2px solid #1554a1;
      padding: 10px;
      color: #1554a1;
    }

    td {
      padding: 12px 10px;
      border-bottom: 1px solid #ddd;
    }

    .right {
      text-align: right;
    }

    .totals {
      margin-top: 20px;
      width: 300px;
      float: right;
    }

    .totals div {
      display: flex;
      justify-content: space-between;
      margin: 5px 0;
    }

    .total-final {
      color: #1554a1;
      font-weight: bold;
    }

    .footer {
      padding: 30px;
      text-align: center;
      margin-top: 40px;
      color: #1554a1;
      font-style: italic;
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <div class="header">
    <div class="logo">LOGO</div>

    <div class="invoice-info">
 <h2>DELIVERY NOTE</h2>

<p>No: {{numero}}</p>
<p>Date: {{date}}</p>

    </div>
  </div>

  <!-- CLIENT -->
  <div class="section">
    <h3>Client</h3>
<p>{{clientName}}</p>
<p>{{clientEmail}}</p>
<p>{{clientPhone}}</p>
  </div>

  <!-- TABLE -->
  <div class="section">
    <table>
<thead>
  <tr>
    <th>Description</th>
      <th>Quantity</th>
      <th>Unity</th>
  </tr>
</thead>

  <tbody>
    {{#each items}}
    <tr>
      <td>{{this.description}}</td>
      <td>{{this.quantity}}</td>
      <td>{{this.unity}}</td>
    </tr>
    {{/each}}
  </tbody>
    </table>

    <!-- TOTAL -->


  <!-- FOOTER -->
  <div class="footer">
    Merci pour votre confiance !
  </div>

</body>
</html>